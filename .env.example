# PredictFlow environment. Copy to `.env.local` to override defaults.
# All VITE_* vars are inlined into the browser bundle at build time —
# NEVER put secrets here. Server-side secrets belong in a backend.

# ── DFlow ──────────────────────────────────────────────────────────
# Same-origin proxy paths. The browser only ever talks to these — the
# real DFlow hosts and the API key live server-side in the Cloudflare
# Pages Functions under functions/api/ (or in vite.config.js for dev).
VITE_DFLOW_PROXY_BASE=/api/dflow
VITE_DFLOW_QUOTE_URL=/api/dflow-quote
VITE_DFLOW_ORDER_URL=/api/dflow-order
# Dev proxy targets (read by vite.config.js — no VITE_ prefix, so these
# never enter import.meta.env and never end up in the browser bundle).
# Same names as the Cloudflare Pages dashboard so .env stays 1:1 with prod.
DFLOW_UPSTREAM=https://dev-prediction-markets-api.dflow.net
DFLOW_QUOTE_UPSTREAM=https://dev-quote-api.dflow.net/quote
DFLOW_ORDER_UPSTREAM=https://dev-quote-api.dflow.net/order
# DFlow API key. Leave empty in dev unless your dev cluster requires it.
# In prod this is set in the Cloudflare Pages dashboard as a Secret.
DFLOW_API_KEY=
# Real-time price stream. Leave empty to disable; subscription shape is
# best-effort and may need to match DFlow's actual protocol.
VITE_DFLOW_WS_URL=wss://api.prod.dflow.net/ws
VITE_DFLOW_DOCS_URL=https://docs.dflow.net
# Comma-separated program IDs to whitelist for txDecoder (beyond the
# standard System / SPL Token / ATA / ComputeBudget / Memo programs and
# the DFlow Prediction Markets program, which are pinned in code).
# Add anything else DFlow's router calls into here — e.g. a future
# versioned settlement program.
VITE_DFLOW_ALLOWED_PROGRAMS=

# Optional REST fallback for live prices when no WS is available.
# If set, useConditionalOrders will poll this URL instead of drifting.
VITE_LIVE_PRICE_URL=

# ── Solana ────────────────────────────────────────────────────────
# Network label shown in the footer ("mainnet" or "devnet"). Keep this
# in sync with VITE_SOLANA_RPC_ENDPOINTS below — this is a display hint
# only, not used for routing.
VITE_SOLANA_NETWORK=mainnet
# Comma-separated RPCs in preferred order. Use a paid provider
# (Helius / Triton / QuickNode) in prod — the public endpoints are
# heavily rate-limited.
#
# Recommended: keep this as the same-origin path `/api/rpc` and put the
# real provider URL in HELIUS_RPC_URL below. The browser then only ever
# talks to your own origin, which means:
#   • Helius/QuickNode/Triton domain allowlists never apply (the upstream
#     hit comes from your edge, not the user's browser — useful when you
#     can't allowlist `localhost` for dev keys).
#   • The api-key never enters the browser bundle.
# In dev, /api/rpc is handled by the solanaRpcDevPlugin in vite.config.js;
# in prod by functions/api/rpc.js. Set HELIUS_RPC_URL in both.
VITE_SOLANA_RPC_ENDPOINTS=/api/rpc

# Server-side RPC URL the /api/rpc proxy forwards to (no VITE_ prefix —
# stays out of the browser bundle). Include the api-key in the query
# string. In Cloudflare Pages prod, set this as a Secret in the dashboard.
HELIUS_RPC_URL=
VITE_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
VITE_SPL_TOKEN_PROGRAM=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA

# ── KYC ───────────────────────────────────────────────────────────
# Where the "Verify with Proof" button sends the user.
VITE_PROOF_URL=https://www.dflow.net/proof
# Backend endpoint that returns `{ verified: boolean, reason?: string }` for
# the current wallet. When set, KYC status comes from the server instead of
# a client-trust checkbox. The default value points at the Cloudflare Pages
# Function in functions/api/dflow-kyc-check.js, which delegates the check to
# DFlow's /order endpoint (DFlow is the source of truth — there is no public
# Proof status API). Set to empty string to fall back to client-side
# self-attestation in demo mode.
VITE_KYC_CHECK_URL=/api/dflow-kyc-check

# ── Observability ─────────────────────────────────────────────────
# Leave empty to disable. Both integrations are loaded lazily.
VITE_SENTRY_DSN=
VITE_ANALYTICS_PROVIDER=         # '', 'posthog', 'plausible', 'custom'
VITE_ANALYTICS_WRITE_KEY=
VITE_ANALYTICS_HOST=

# ── Safety flags ──────────────────────────────────────────────────
# DANGEROUS. Default: off in prod, on in dev.
# When true, the UI will fake YES/NO mint addresses for markets that
# don't publish real ones. Real swaps cannot route against these —
# only leave on in non-money environments.
VITE_ALLOW_SYNTHESIZED_MINTS=false
# When true, if DFlow /order fails the UI pretends the trade filled.
# Useful for offline demos, catastrophic for real money.
VITE_ALLOW_SIMULATED_FILLS=false

# ── Legal ─────────────────────────────────────────────────────────
VITE_TERMS_URL=
VITE_PRIVACY_URL=
VITE_RISK_URL=
VITE_SUPPORT_EMAIL=

# ── Monetization ──────────────────────────────────────────────────
# Solana pubkey that receives platform swap fees and tier subscription
# payments. Required for on-chain fee collection — when unset (or left
# at the placeholder), the app records would-be fee events in the
# admin revenue dashboard but does not transfer USDC.
VITE_FEE_WALLET=

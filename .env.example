# PredictFlow environment. Copy to `.env.local` to override defaults.
# All VITE_* vars are inlined into the browser bundle at build time —
# NEVER put secrets here. Server-side secrets belong in a backend.

# ── DFlow ──────────────────────────────────────────────────────────
# Base path for the market/event REST API (proxied via your host in prod).
VITE_DFLOW_PROXY_BASE=/api/dflow
# Dev proxy upstream host (Vite server only, not shipped to client).
# Set this when you want `npm run dev` to hit prod DFlow instead of dev.
VITE_DFLOW_UPSTREAM=https://dev-prediction-markets-api.dflow.net
# Absolute URLs for the quote + order endpoints (not proxied — direct call).
# Defaults match the current dev endpoints. Swap for prod hosts per DFlow docs.
VITE_DFLOW_QUOTE_URL=https://dev-quote-api.dflow.net/quote
VITE_DFLOW_ORDER_URL=https://dev-quote-api.dflow.net/order
# Real-time price stream. Leave empty to disable; subscription shape is
# best-effort and may need to match DFlow's actual protocol.
VITE_DFLOW_WS_URL=wss://api.prod.dflow.net/ws
VITE_DFLOW_DOCS_URL=https://docs.dflow.net
# Comma-separated program IDs to whitelist for txDecoder (beyond the
# standard System / SPL Token / ATA / ComputeBudget / Memo programs).
# Populate with DFlow's router program ID(s) before going to prod.
VITE_DFLOW_ALLOWED_PROGRAMS=

# Optional REST fallback for live prices when no WS is available.
# If set, useConditionalOrders will poll this URL instead of drifting.
VITE_LIVE_PRICE_URL=

# ── Solana ────────────────────────────────────────────────────────
# Comma-separated RPCs in preferred order. Use a paid provider
# (Helius / Triton / QuickNode) in prod — the public endpoints are
# heavily rate-limited.
VITE_SOLANA_RPC_ENDPOINTS=https://api.mainnet-beta.solana.com
VITE_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
VITE_SPL_TOKEN_PROGRAM=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA

# ── KYC ───────────────────────────────────────────────────────────
# Where the "Verify with Proof" button sends the user.
VITE_PROOF_URL=https://www.dflow.net/proof
# Backend endpoint that returns `{ verified: boolean }` for the current
# wallet. When set, KYC status comes from the server instead of a
# client-trust checkbox. Leave empty in demo mode.
VITE_KYC_CHECK_URL=

# ── Observability ─────────────────────────────────────────────────
# Leave empty to disable. Both integrations are loaded lazily.
VITE_SENTRY_DSN=
VITE_ANALYTICS_PROVIDER=         # '', 'posthog', 'plausible', 'custom'
VITE_ANALYTICS_WRITE_KEY=
VITE_ANALYTICS_HOST=

# ── Safety flags ──────────────────────────────────────────────────
# DANGEROUS. Default: off in prod, on in dev.
# When true, the UI will fake YES/NO mint addresses for markets that
# don't publish real ones. Real swaps cannot route against these —
# only leave on in non-money environments.
VITE_ALLOW_SYNTHESIZED_MINTS=false
# When true, if DFlow /order fails the UI pretends the trade filled.
# Useful for offline demos, catastrophic for real money.
VITE_ALLOW_SIMULATED_FILLS=false

# ── Legal ─────────────────────────────────────────────────────────
VITE_TERMS_URL=
VITE_PRIVACY_URL=
VITE_RISK_URL=
VITE_SUPPORT_EMAIL=
